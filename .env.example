# ── GitHub App credentials ───────────────────────────────────────────────────
APP_ID=
PRIVATE_KEY_PATH=./private-key.pem
INSTALLATION_ID=

# ── MySQL / DevLake DB ────────────────────────────────────────────────────────
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=lake

# ── Optional ──────────────────────────────────────────────────────────────────
# Set to true to print debug-level logs to console (always written to log files)
DEBUG=false
